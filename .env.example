# --- Backend (Railway) ---
OPENAI_API_KEY=sk-...
STRIPE_SECRET_KEY=sk_test_...        # test mode -> real ACP PaymentIntent; blank/non-test -> mock
EXA_API_KEY=...                      # required for live venue discovery

# Live venue discovery (real Exa results into planning for non-ORK sessions)
USE_EXA=true
USE_EXA_IN_PLANNING=true

# Comma-separated allowed origins for CORS — set to your Vercel URL in prod
CORS_ORIGINS=http://localhost:3000

# --- Faithful x402 booking payment (Base Sepolia) ---
# OFF by default. When true, the Convener pays the merchant's x402-protected
# booking endpoint over a real HTTP 402 handshake before the receipt is issued.
USE_REAL_X402=false
# When true, a failed x402 attempt is a controlled failure (no Stripe/mock
# fallback). When false, x402 failures fall back so the demo continues.
REQUIRE_REAL_X402=false
X402_NETWORK=eip155:84532
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_BOOKING_PRICE=$0.001
# Public merchant receiving address — safe to display.
X402_MERCHANT_PAY_TO=0xMerchantReceivingWalletAddress
# SECRET — the Convener/buyer EVM private key (0x + 64 hex). NEVER commit a real
# value; set it only in the local .env / Railway variables, never here.
EVM_PRIVATE_KEY=0xConvenerBuyerPrivateKey_DO_NOT_COMMIT
# Where the buyer reaches the merchant endpoint. Local default below; on Railway
# set this to the public backend URL.
X402_RESOURCE_BASE_URL=http://localhost:8000

# --- Frontend (Vercel) ---
# NEXT_PUBLIC_API_URL=https://<your-app>.up.railway.app
