# --- Backend (Railway) ---
OPENAI_API_KEY=sk-...
STRIPE_SECRET_KEY=sk_test_...        # test mode -> real ACP PaymentIntent; blank/non-test -> mock
EXA_API_KEY=...                      # required for live venue discovery

# Live venue discovery (real Exa results into planning for non-ORK sessions)
USE_EXA=true
USE_EXA_IN_PLANNING=true

# Comma-separated allowed origins for CORS — set to your Vercel URL in prod
CORS_ORIGINS=http://localhost:3000

# --- Frontend (Vercel) ---
# NEXT_PUBLIC_API_URL=https://<your-app>.up.railway.app
